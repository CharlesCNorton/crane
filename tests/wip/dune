(include_subdirs qualified)

(env (_ (env-vars (INSIDE_DUNE "1"))))

(coq.theory
 (name CraneTestsWIP)
 (synopsis "Tests for the rocq-crane plugin")
 (modules :standard) ; automatically includes all .v files in this directory
 (theories
   Stdlib
   Crane)
 (flags (:standard -output-directory ../../tests/wip)))


(subdir decode_list_empty
 (rule
  (targets decode_list_empty.t.exe)
  (deps DecodeListEmpty.vo decode_list_empty.t.cpp (source_tree .))
  (action
   (run %{project_root}/scripts/compile-std.sh %{project_root} decode_list_empty.t.exe decode_list_empty.cpp decode_list_empty.t.cpp)))
 (rule
  (alias runtest)
  (deps decode_list_empty.t.exe)
  (action (run ./decode_list_empty.t.exe))))

